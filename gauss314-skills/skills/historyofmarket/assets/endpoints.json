{
  "_meta": {
    "source": "https://historyofmarket.com/_manifest.json",
    "description": "Snapshot completo de todos los endpoints de historyofmarket.com",
    "total_datasets": 88,
    "license": "CC BY 4.0",
    "updated": "2026-06-13",
    "base_url": "https://historyofmarket.com",
    "cache_policy": "max-age=300, stale-while-revalidate=3600, ETag supported",
    "notes": [
      "Todos los datasets son JSON estaticos pre-generados (sin parametros)",
      "No hay endpoints parametrizables tipo ?symbol=QQQ",
      "ETF holdings solo disponibles para XLK, XLF, SMH",
      "No hay Russell 2000 ni otros indices fuera de los listados",
      "Para reconstruir constituyentes historicos: aplicar changes.json en reversa desde constituents.json"
    ]
  },
  "entry_points": {
    "description": "Utilidades del sitio",
    "endpoints": [
      { "path": "/api/_manifest.json", "description": "Catalogo completo de todos los datasets con tamano y timestamp" },
      { "path": "/api/profile.json", "description": "Perfil del sitio para AI agents (proposito, preguntas, licencia)" },
      { "path": "/api/tools.json", "description": "Lista machine-callable de 68 tools (MCP-style)" },
      { "path": "/llms.txt", "description": "Resumen LLM-friendly del sitio" },
      { "path": "/llms-full.txt", "description": "Version extendida de llms.txt" },
      { "path": "/.well-known/llms.txt", "description": "Well-known location estandar" },
      { "path": "/ai.txt", "description": "AI agent instructions" },
      { "path": "/sitemap.xml", "description": "Sitemap completo (60+ panels x 6 locales)" },
      { "path": "/robots.txt", "description": "Robots.txt" }
    ]
  },
  "sp500": {
    "description": "S&P 500 — 18 datasets",
    "group_prices_returns": {
      "description": "Precios y retornos",
      "endpoints": [
        { "path": "/api/sp500/century.json", "description": "S&P 500 daily closes desde 1928" },
        { "path": "/api/sp500/price.json", "description": "S&P 500 daily price (version pesada, ~1.5MB)" },
        { "path": "/api/sp500/annual-returns.json", "description": "Retornos anuales S&P 500, 1928→ (73 positivos, 26 negativos)" },
        { "path": "/api/sp500/annual-tr.json", "description": "Retorno total anual (para matriz buy/sell y rolling windows)" },
        { "path": "/api/sp500/daily-distribution.json", "description": "Distribucion de retornos diarios" },
        { "path": "/api/sp500/daily-extremes.json", "description": "Extremos diarios historicos" }
      ]
    },
    "group_drawdowns_volatility": {
      "description": "Drawdowns y volatilidad",
      "endpoints": [
        { "path": "/api/sp500/drawdowns.json", "description": "Registro completo de drawdowns desde 1929 con causa y dias de recuperacion" },
