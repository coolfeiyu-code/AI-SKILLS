        { "path": "/api/sp500/volatility.json", "description": "Volatilidad realizada 20d/60d (mediana ~15%)" },
        { "path": "/api/sp500/vix.json", "description": "VIX daily desde 1990" },
        { "path": "/api/sp500/monthly.json", "description": "Heatmap mensual con probabilidades de ganancia" }
      ]
    },
    "group_valuation": {
      "description": "Valuacion",
      "endpoints": [
        { "path": "/api/sp500/pe.json", "description": "Shiller CAPE (PE10) desde 1871 (~148KB)" },
        { "path": "/api/sp500/forward-pe.json", "description": "Trailing PE diario + Forward PE Bloomberg desde 1990" },
        { "path": "/api/sp500/eps.json", "description": "GAAP TTM EPS desde 1871" },
        { "path": "/api/sp500/roe.json", "description": "Return on equity (estable ~15% ultimas 2 decadas)" },
        { "path": "/api/sp500/driver-decomp.json", "description": "Descomposicion anual: (1+r) = (1+r_PE)*(1+r_EPS), 1928→" },
        { "path": "/api/sp500/return-details.json", "description": "Descomposicion total return: price + dividend + buyback" }
      ]
